<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="25.0" styleClass="main-content" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ecommerce.controller.ProfileController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
        <StackPane alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            
            <VBox fx:id="card" maxWidth="500.0" spacing="20.0" style="-fx-background-color: #1e1e1e; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                <padding>
                    <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="👤 My Profile" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleRefresh" styleClass="button-secondary" text="🔄" />
                </HBox>
                <Label text="Manage your personal information and security" style="-fx-text-fill: #b0b0b0;" />
                
                <Separator style="-fx-background-color: #333;" />

                <!-- View Mode Grid -->
                <GridPane fx:id="infoGrid" hgap="20.0" vgap="15.0">
                    <Label text="Full Name:" style="-fx-text-fill: #b0b0b0; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <Label fx:id="nameDisplayLabel" style="-fx-text-fill: white; -fx-font-size: 16px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    
                    <Label text="Email Address:" style="-fx-text-fill: #b0b0b0; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <Label fx:id="emailDisplayLabel" style="-fx-text-fill: white; -fx-font-size: 16px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    
                    <Label text="Location:" style="-fx-text-fill: #b0b0b0; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <Label fx:id="locationDisplayLabel" style="-fx-text-fill: white; -fx-font-size: 16px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                </GridPane>

                <!-- Edit Mode Controls -->
                <VBox fx:id="editControls" managed="false" spacing="15.0" visible="false">
                    <Label style="-fx-font-weight: bold;" text="Full Name" textFill="WHITE" />
                    <TextField fx:id="nameField" prefHeight="40.0" styleClass="form-field" />
                    
                    <Label style="-fx-font-weight: bold;" text="Email Address" textFill="WHITE" />
                    <TextField fx:id="emailField" prefHeight="40.0" styleClass="form-field" />
                    
                    <Label style="-fx-font-weight: bold;" text="Location" textFill="WHITE" />
                    <TextField fx:id="locationField" prefHeight="40.0" styleClass="form-field" />
                    
                    <Label style="-fx-font-weight: bold;" text="Change Password (optional)" textFill="WHITE" />
                    <HBox fx:id="passBox" alignment="CENTER_LEFT" spacing="5.0">
                        <StackPane HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="passField" prefHeight="40.0" promptText="New Password" />
                            <TextField fx:id="passVisible" managed="false" prefHeight="40.0" promptText="New Password" visible="false" />
                        </StackPane>
                        <Button onAction="#togglePassVisibility" prefHeight="40.0" prefWidth="48.0" style="-fx-background-color: #2a2a2a; -fx-text-fill: #aaa; -fx-font-size: 18px; -fx-cursor: hand; -fx-border-color: #444; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 0;" text="◎" />
                    </HBox>
                    
                    <Label style="-fx-font-weight: bold;" text="Confirm New Password" textFill="WHITE" />
                    <HBox fx:id="confirmBox" alignment="CENTER_LEFT" spacing="5.0">
                        <StackPane HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="confirmPassField" prefHeight="40.0" promptText="Confirm New Password" />
                            <TextField fx:id="confirmPassVisible" managed="false" prefHeight="40.0" promptText="Confirm New Password" visible="false" />
                        </StackPane>
                        <Button onAction="#togglePassVisibility" prefHeight="40.0" prefWidth="48.0" style="-fx-background-color: #2a2a2a; -fx-text-fill: #aaa; -fx-font-size: 18px; -fx-cursor: hand; -fx-border-color: #444; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 0;" text="◎" />
                    </HBox>
                </VBox>

                <!-- Buttons -->
                <HBox alignment="CENTER" spacing="15.0">
                    <Button fx:id="editBtn" onAction="#enterEditMode" prefWidth="150.0" styleClass="button-primary" text="Edit Profile" />
                    <Button fx:id="saveBtn" managed="false" onAction="#handleUpdate" styleClass="button-success" text="Save Changes" visible="false" />
                    <Button fx:id="cancelBtn" managed="false" onAction="#exitEditMode" styleClass="button-danger" text="Cancel" visible="false" />
                </HBox>

                <Label fx:id="statusLabel" wrapText="true" />
            </VBox>
        </StackPane>
    </ScrollPane>
</VBox>
