<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" styleClass="main-content" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ecommerce.controller.ProductController">
    <padding>
        <Insets bottom="0.0" left="0.0" right="0.0" top="0.0" />
    </padding>

    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <!-- Header -->
            <VBox spacing="5.0">
                <Label styleClass="content-title" text="📦  Browse Products" />
                <Label styleClass="content-subtitle" text="Search, filter, and explore our product catalog" />
            </VBox>

            <!-- Search Card -->
            <VBox spacing="15.0" styleClass="card">
                <HBox alignment="BOTTOM_LEFT" spacing="12.0">
                    <VBox spacing="4.0">
                        <Label styleClass="form-label" text="Search:" />
                        <TextField fx:id="searchField" prefHeight="35.0" prefWidth="300.0" promptText="Search products by name..." HBox.hgrow="ALWAYS" />
                    </VBox>
                    <VBox spacing="4.0">
                        <Label styleClass="form-label" text="Category:" />
                        <ComboBox fx:id="categoryFilter" prefHeight="35.0" prefWidth="180.0" promptText="All Categories" />
                    </VBox>
                    <VBox spacing="4.0">
                        <Label styleClass="form-label" text="Sort:" />
                        <ComboBox fx:id="sortCombo" prefHeight="35.0" prefWidth="180.0" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <Button onAction="#handleClearFilters" styleClass="button-secondary" text="Clear Filters" />
                    <Button onAction="#handleSearch" styleClass="button-primary" text="🔄 Refresh" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label fx:id="resultCountLabel" styleClass="label-muted" text="Showing 0 products" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="timingLabel" styleClass="label-muted" text="" />
                </HBox>
            </VBox>

            <!-- Table -->
            <TableView fx:id="productTable" minHeight="400.0" VBox.vgrow="ALWAYS" />

            <!-- Pagination -->
            <HBox alignment="CENTER" spacing="15.0" styleClass="pagination-bar">
                <Button onAction="#handlePrevPage" text="◀  Previous" />
                <Label fx:id="pageLabel" styleClass="page-label" text="Page 1 of 1" />
                <Button onAction="#handleNextPage" text="Next  ▶" />
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
